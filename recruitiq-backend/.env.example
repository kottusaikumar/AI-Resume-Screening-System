# Backend environment variables
# Copy this file to .env and fill in values if needed

# Host and port (defaults shown)
HOST=0.0.0.0
PORT=8000

# Cache directory (defaults to ./data/cache)
# CACHE_DIR=./data/cache

# --- Security settings -------------------------------------------------
# Shared secret required on every request (as the X-API-Key header).
# Leave blank to disable auth entirely (fine for local-only development,
# NOT recommended if this server is reachable by anyone else).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Comma-separated list of frontend origins allowed to call this API.
# Must match where your frontend is actually running (check the URL Vite
# prints when you run `npm run dev`).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080

# Max resume upload size in MB, enforced on the server (not just the UI).
MAX_UPLOAD_MB=10

# Max characters allowed in the job_description / mandatory_skills text fields.
MAX_TEXT_FIELD_CHARS=50000

# Rate limit for the expensive /api/analyze endpoint (per client IP).
ANALYZE_RATE_LIMIT=10/minute

# Default rate limit applied to every other endpoint (per client IP).
DEFAULT_RATE_LIMIT=60/minute

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
